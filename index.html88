<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Solar Media | Sonic Architecture</title>
    <style>
        /* === BASE & TYPOGRAPHY === */
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; }
        
        body, html { 
            background-color: #020204; 
            color: #fff; 
            overflow-x: hidden; 
            width: 100%; 
            scroll-behavior: smooth; 
        }

        ::selection { background: #fff; color: #000; }
        html { scrollbar-width: none; }
        ::-webkit-scrollbar { display: none; }

        /* === SHOCKWAVE & STAR BACKGROUND === */
        #space { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 0; pointer-events: none; }
        #glass-overlay {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(0, 0, 0, 0.45); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
            z-index: 1; pointer-events: none;
        }

        main, footer { position: relative; z-index: 10; }

        /* === TRANSLUCENT GLASS NAVIGATION === */
        header {
            position: fixed; top: 0; left: 0; width: 100%; padding: 20px 5vw;
            display: flex; justify-content: space-between; align-items: center;
            z-index: 1000; background: rgba(5, 5, 8, 0.5); backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.08); box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
        }
        .logo-container { display: flex; align-items: center; gap: 15px; cursor: pointer; text-decoration: none; color: #fff; }
        .nav-logo-img { height: 35px; width: auto; mix-blend-mode: screen; } 
        .logo-text { font-size: 1.2rem; font-weight: 900; letter-spacing: 4px; text-transform: uppercase; }
        
        .nav-links { display: flex; gap: 40px; }
        .nav-link { 
            color: #fff; text-decoration: none; font-size: 0.75rem; font-weight: 600; 
            letter-spacing: 2px; text-transform: uppercase; position: relative; overflow: hidden;
        }
        .nav-link::after {
            content: ''; position: absolute; bottom: -4px; left: -100%; width: 100%; height: 1px;
            background: #fff; transition: left 0.4s cubic-bezier(0.19, 1, 0.22, 1);
        }
        .nav-link:hover::after { left: 0; }

        /* === LAYOUT & SCROLL REVEALS === */
        section { padding: 15vh 5vw; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; position: relative; }
        .reveal { opacity: 0; transform: translateY(40px); transition: opacity 1s cubic-bezier(0.2, 0.8, 0.2, 1), transform 1s cubic-bezier(0.2, 0.8, 0.2, 1); }
        .reveal.active { opacity: 1; transform: translateY(0); }

        /* === HERO SECTION === */
        .hero { justify-content: flex-end; padding-bottom: 10vh; }
        .hero-logo-img { width: 120px; height: auto; mix-blend-mode: screen; margin-bottom: 20px; opacity: 0.9; }
        .hero h1 { font-size: clamp(3rem, 10vw, 8rem); font-weight: 900; letter-spacing: -2px; line-height: 0.9; text-transform: uppercase; margin-bottom: 20px; }
        .hero p { font-size: clamp(1rem, 2vw, 1.2rem); font-weight: 300; letter-spacing: 4px; color: #ccc; text-transform: uppercase; max-width: 600px; }
        
        .scroll-indicator { position: absolute; bottom: 5vh; right: 5vw; width: 1px; height: 80px; background: rgba(255,255,255,0.2); overflow: hidden; }
        .scroll-indicator::after { content: ''; position: absolute; top: -100%; left: 0; width: 100%; height: 100%; background: #fff; animation: scrollLine 2s infinite ease-in-out; }
        @keyframes scrollLine { 0% { top: -100%; } 100% { top: 100%; } }

        /* === MANIFESTO SECTION === */
        /* FIX: Removed the 100vh minimum height and adjusted padding so it hugs the text */
        #manifesto { min-height: auto; padding-bottom: 5vh; padding-top: 10vh; }
        .manifesto-layout { display: grid; grid-template-columns: 1fr 2fr; gap: 5vw; align-items: start; border-top: 1px solid rgba(255,255,255,0.15); padding-top: 80px; }
        .manifesto-title h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; text-transform: uppercase; letter-spacing: 2px; }
        .manifesto-title p { color: #888; font-size: 0.9rem; letter-spacing: 2px; text-transform: uppercase; margin-top: 10px; }
        .manifesto-text p { color: #ccc; line-height: 1.8; font-size: 1rem; margin-bottom: 25px; text-transform: uppercase; letter-spacing: 1px; }
        .manifesto-text strong { color: #fff; font-weight: 700; }

        /* === SPOTIFY EMBED SECTION === */
        /* FIX: Removed 100vh minimum height to pull it closer to the manifesto */
        #transmission { min-height: auto; padding-top: 5vh; padding-bottom: 10vh; }
        .spotify-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 5vw; align-items: center; border-top: 1px solid rgba(255,255,255,0.15); padding-top: 80px; }
        .section-title h2 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; text-transform: uppercase; letter-spacing: 2px; margin-bottom: 20px; }
        .section-title p { color: #888; font-size: 0.9rem; letter-spacing: 2px; text-transform: uppercase; line-height: 1.6; }
        .spotify-container { width: 100%; border-radius: 12px; overflow: hidden; box-shadow: 0 10px 40px rgba(0,0,0,0.8); border: 1px solid rgba(255,255,255,0.1); }

        /* === HORIZONTAL RELEASES MARQUEE === */
        .releases-section { padding: 10vh 0; min-height: auto; overflow: hidden; }
        .releases-header { padding: 0 5vw; margin-bottom: 40px; }
        .releases-header h2 { font-size: 2rem; font-weight: 800; text-transform: uppercase; letter-spacing: 2px; }
        
        .marquee-wrapper { width: 100%; overflow: hidden; position: relative; padding: 20px 0; }
        .marquee-wrapper::before, .marquee-wrapper::after { content: ''; position: absolute; top: 0; width: 150px; height: 100%; z-index: 2; pointer-events: none; }
        .marquee-wrapper::before { left: 0; background: linear-gradient(to right, rgba(2,2,4,1) 0%, transparent 100%); }
        .marquee-wrapper::after { right: 0; background: linear-gradient(to left, rgba(2,2,4,1) 0%, transparent 100%); }
        
        .marquee-track { display: flex; gap: 40px; width: max-content; animation: scrollMarquee 25s linear infinite; }
        @keyframes scrollMarquee { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

        .release-item { width: 280px; display: flex; flex-direction: column; gap: 15px; }
        .release-cover { width: 100%; aspect-ratio: 1/1; object-fit: cover; border-radius: 4px; filter: grayscale(100%); transition: 0.4s; border: 1px solid rgba(255,255,255,0.1); }
        .release-item:hover .release-cover { filter: grayscale(0%); transform: scale(1.02); border-color: rgba(255,255,255,0.4); }
        .release-info h3 { font-size: 1.2rem; font-weight: 800; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 5px; }
        .release-info p { font-size: 0.75rem; color: #888; text-transform: uppercase; letter-spacing: 2px; }
        
        .spotify-btn { display: inline-block; background: transparent; border: 1px solid rgba(255,255,255,0.3); color: #fff; padding: 10px 20px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; cursor: pointer; text-decoration: none; transition: 0.3s; margin-top: 10px; text-align: center; }
        .spotify-btn:hover { background: #1DB954; border-color: #1DB954; color: #000; }

        /* === DEMO SUBMISSION FORM === */
        .contact-layout { display: flex; flex-direction: column; align-items: center; text-align: center; max-width: 800px; margin: 0 auto; background: rgba(0,0,0,0.5); padding: 60px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); backdrop-filter: blur(10px); }
        .contact-layout h2 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; text-transform: uppercase; letter-spacing: -1px; margin-bottom: 20px; }
        .contact-layout p { color: #888; font-size: 0.8rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 40px; }
        
        form { width: 100%; display: flex; flex-direction: column; gap: 40px; text-align: left; }
        .input-row { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; }
        
        .input-group { position: relative; }
        .input-group label { position: absolute; top: 0; left: 0; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 2px; color: #888; transition: 0.3s; pointer-events: none; }
        
        input, textarea { width: 100%; background: transparent; border: none; border-bottom: 1px solid rgba(255,255,255,0.2); color: #fff; padding: 25px 0 10px 0; font-size: 1.2rem; outline: none; border-radius: 0; transition: border-color 0.4s; }
        textarea { resize: none; height: 100px; }
        input:focus, textarea:focus, input:valid, textarea:valid { border-bottom-color: #fff; }
        input:focus ~ label, input:valid ~ label, textarea:focus ~ label, textarea:valid ~ label { top: -10px; font-size: 0.65rem; color: #fff; }

        .sharp-btn { background: rgba(255,255,255,0.05); border: 1px solid #fff; color: #fff; padding: 20px 50px; font-size: 0.85rem; font-weight: 700; text-transform: uppercase; letter-spacing: 3px; cursor: pointer; position: relative; overflow: hidden; transition: color 0.4s; margin-top: 20px; width: fit-content; align-self: center; backdrop-filter: blur(5px); }
        .sharp-btn::before { content: ''; position: absolute; top: 0; left: -100%; width: 100%; height: 100%; background: #fff; transition: left 0.4s cubic-bezier(0.19, 1, 0.22, 1); z-index: -1; }
        .sharp-btn:hover { color: #000; }
        .sharp-btn:hover::before { left: 0; }

        footer { padding: 40px 5vw; display: flex; justify-content: space-between; border-top: 1px solid rgba(255,255,255,0.05); font-size: 0.7rem; color: #888; text-transform: uppercase; letter-spacing: 2px; background: rgba(0,0,0,0.6); backdrop-filter: blur(10px); }

        @media (max-width: 900px) {
            header { padding: 20px; }
            .nav-links { display: none; }
            .manifesto-layout { grid-template-columns: 1fr; gap: 30px; padding-top: 50px; }
            .spotify-layout { grid-template-columns: 1fr; gap: 40px; padding-top: 50px; }
            .input-row { grid-template-columns: 1fr; gap: 40px; }
            .contact-layout { padding: 40px 20px; }
            .marquee-wrapper::before, .marquee-wrapper::after { width: 50px; }
        }
    </style>
</head>
<body>
    <canvas id="space"></canvas>
    
    <div id="glass-overlay"></div>

    <header>
        <a href="#" class="logo-container">
            <img src="1000082011.png" alt="Solar Media Logo" class="nav-logo-img">
            <span class="logo-text">Solar</span>
        </a>
        <div class="nav-links">
            <a href="#manifesto" class="nav-link">Manifesto</a>
            <a href="#transmission" class="nav-link">Transmissions</a>
            <a href="#catalog" class="nav-link">Catalog</a>
            <a href="#submit" class="nav-link">Submit</a>
        </div>
    </header>

    <main>
        <section id="hero" class="hero">
            <img src="1000082011.png" alt="Solar Media Emblem" class="hero-logo-img reveal">
            <h1 class="reveal" style="transition-delay: 0.1s;">Solar<br>Media</h1>
            <p class="reveal" style="transition-delay: 0.2s;">Sonic Architecture. We are an independent imprint elevating underground frequencies and defining the future of sound.</p>
            <div class="scroll-indicator reveal" style="transition-delay: 0.3s;"></div>
        </section>

        <section id="manifesto">
            <div class="manifesto-layout reveal">
                <div class="manifesto-title">
                    <h2>The Protocol</h2>
                    <p>By Producers, For Producers</p>
                </div>
                <div class="manifesto-text">
                    <p><strong>Solar Media</strong> is a premier electronic imprint dedicated to the pure, unadulterated frequencies of the underground. Specializing heavily in Brazilian Funk and Phonk, we exist to amplify artists who break the mold and refuse to conform to algorithmic standards.</p>
                    <p>Founded by producers, for producers. We understand the architecture of the independent scene because we live it. We know what it takes to cut through the static, and our mission is to provide a platform that elevates authentic, boundary-pushing music.</p>
                    <p>We aren't just releasing tracks; we are engineering a movement. If your sound hits hard and shifts the culture, this is your home.</p>
                </div>
            </div>
        </section>

        <section id="transmission">
            <div class="spotify-layout">
                <div class="section-title reveal">
                    <h2>Latest<br>Transmission</h2>
                    <p>Stream the newest signals directly from the Solar Media command center. Curated heavy cuts, pristine production, and uncompromising audio architecture.</p>
                </div>
                <div class="spotify-container reveal" style="transition-delay: 0.2s;">
                    <iframe src="https://open.spotify.com/embed/playlist/37i9dQZF1DX0XUsuxWHRQd" width="100%" height="352" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
                </div>
            </div>
        </section>

        <section id="catalog" class="releases-section">
            <div class="releases-header reveal">
                <h2>The Catalog</h2>
            </div>
            <div class="marquee-wrapper reveal" style="transition-delay: 0.2s;">
                <div class="marquee-track" id="dynamic-marquee">
                    <p style="padding: 20px; color: #888;">Establishing connection to catalog...</p>
                </div>
            </div>
        </section>

        <section id="submit">
            <div class="contact-layout reveal">
                <h2>Demo Submission</h2>
                <p>Drop your heaviest cuts. Private links only.</p>
                <form id="demoForm">
                    <div class="input-row">
                        <div class="input-group">
                            <input type="text" id="artistName" required>
                            <label for="artistName">Artist Name</label>
                        </div>
                        <div class="input-group">
                            <input type="email" id="artistEmail" required>
                            <label for="artistEmail">Contact Email</label>
                        </div>
                    </div>
                    <div class="input-row">
                        <div class="input-group">
                            <input type="text" id="artistGenre" required>
                            <label for="artistGenre">Primary Genre</label>
                        </div>
                        <div class="input-group">
                            <input type="url" id="demoLink" required>
                            <label for="demoLink">Private Link (SoundCloud / Drive)</label>
                        </div>
                    </div>
                    <div class="input-group">
                        <textarea id="demoMessage" required></textarea>
                        <label for="demoMessage">Message / Track Details</label>
                    </div>
                    <button type="submit" class="sharp-btn">Transmit Demo</button>
                </form>
            </div>
        </section>
    </main>

    <footer>
        <div>© 2026 Solar Media Recordings</div>
        <div>All Systems Nominal</div>
    </footer>
    <script>
        // ==========================================
        // SOLAR MEDIA NO-CODE AUTO-FETCHER
        // ==========================================
        // Paste your "Publish to Web" CSV link from Google Sheets right here:
        const GOOGLE_SHEET_CSV_URL = "PASTE_YOUR_GOOGLE_SHEET_CSV_LINK_HERE";

        async function autoFetchCatalog() {
            const marquee = document.getElementById('dynamic-marquee');
            if (!marquee) return;

            let catalogTracks = [];

            try {
                // 1. Fetch the links from your Google Sheet
                const sheetResponse = await fetch(GOOGLE_SHEET_CSV_URL);
                const csvText = await sheetResponse.text();
                
                // Parse the spreadsheet rows into clean URLs
                catalogTracks = csvText.split('\n')
                    .map(row => row.split(',')[0].trim().replace(/^"|"$/g, ''))
                    .filter(url => url.includes('spotify.com')); // Only keep valid Spotify links
                    
                if (catalogTracks.length === 0) throw new Error("No Spotify links found in sheet.");
                
            } catch (err) {
                console.error("Failed to connect to Google Sheet database.", err);
                marquee.innerHTML = "<p style='padding: 20px; color: #d82c2c;'>Error connecting to catalog database.</p>";
                return;
            }

            let htmlContent = "";

            // 2. Fetch the cover art and details from Spotify for each link
            for (const link of catalogTracks) {
                try {
                    const oembedUrl = `https://open.spotify.com/oembed?url=${link}`;
                    const response = await fetch(`https://api.allorigins.win/get?url=${encodeURIComponent(oembedUrl)}`);
                    const data = await response.json();
                    const trackData = JSON.parse(data.contents);

                    htmlContent += `
                    <div class="release-item">
                        <img src="${trackData.thumbnail_url}" alt="Cover" class="release-cover">
                        <div class="release-info">
                            <h3>${trackData.title.split(' - ')[0] || trackData.title}</h3>
                            <p>Release • ${trackData.author_name}</p>
                            <a href="${link}" target="_blank" class="spotify-btn">Listen on Spotify</a>
                        </div>
                    </div>
                    `;
                } catch (error) {
                    console.error("Failed to load catalog data for: ", link);
                }
            }

            // Duplicate the content so the marquee scrolls infinitely without gaps
            marquee.innerHTML = htmlContent + htmlContent;
        }

        // Initialize the auto-fetcher
        autoFetchCatalog();

        // --- DEMO FORM MAILTO LOGIC ---
        document.getElementById('demoForm').addEventListener('submit', function(e) {
            e.preventDefault(); 
            const name = document.getElementById('artistName').value;
            const email = document.getElementById('artistEmail').value;
            const genre = document.getElementById('artistGenre').value;
            const link = document.getElementById('demoLink').value;
            const message = document.getElementById('demoMessage').value;

            const labelEmail = "demo@solarmedia.net"; // Update this email
            const subject = encodeURIComponent(`DEMO: ${name} - ${genre}`);
            const bodyText = `Artist Name: ${name}\nContact Email: ${email}\nGenre: ${genre}\n\nPrivate Link:\n${link}\n\nMessage:\n${message}\n\n---\nSolar Media System`;
            const body = encodeURIComponent(bodyText);

            window.location.href = `mailto:${labelEmail}?subject=${subject}&body=${body}`;
            this.reset();
        });

        // --- RELIABLE SCROLL REVEAL ANIMATIONS ---
        const observerOptions = { root: null, rootMargin: '0px 0px -50px 0px', threshold: 0.1 };
        const observer = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                    observer.unobserve(entry.target); 
                }
            });
        }, observerOptions);

        document.querySelectorAll('.reveal').forEach(el => { observer.observe(el); });

        setTimeout(() => {
            document.querySelectorAll('.reveal').forEach(el => {
                const rect = el.getBoundingClientRect();
                if(rect.top < window.innerHeight) { el.classList.add('active'); }
            });
        }, 50);

        // --- BACKGROUND CANVAS LOGIC ---
        const canvas = document.getElementById("space");
        const ctx = canvas.getContext("2d");
        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;

        window.addEventListener('resize', () => { 
            width = canvas.width = window.innerWidth; 
            height = canvas.height = window.innerHeight; 
        });

        const stars = Array.from({ length: 900 }, () => ({
            x: Math.random() * width,
            y: Math.random() * height,
            size: Math.random() * 2 + 0.5, 
            opacity: Math.random(),
            speedX: (Math.random() - 0.5) * 0.3,
            speedY: (Math.random() - 0.5) * 0.3
        }));

        class Shockwave {
            constructor() {
                this.x = width / 2;
                this.y = height / 2;
                this.radius = 20;
                this.opacity = 0.8; 
                this.speed = Math.random() * 2 + 1; 
                this.thickness = Math.random() * 1.5 + 0.5;
            }
            update() { this.radius += this.speed; this.opacity -= 0.003; }
            draw() {
                if (this.opacity <= 0) return;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                ctx.strokeStyle = `rgba(255, 255, 255, ${this.opacity})`;
                ctx.lineWidth = this.thickness;
                ctx.stroke();
            }
        }

        class ShootingStar {
            constructor() {
                this.x = Math.random() * width;
                this.y = Math.random() * height / 2; 
                this.angle = Math.PI / 4 + (Math.random() * 0.2 - 0.1); 
                this.speed = Math.random() * 15 + 10; 
                this.length = Math.random() * 120 + 60; 
                this.opacity = 1;
                this.fadeRate = Math.random() * 0.015 + 0.01;
                this.thickness = Math.random() * 2 + 1;
            }
            update() {
                this.x += Math.cos(this.angle) * this.speed;
                this.y += Math.sin(this.angle) * this.speed;
                this.opacity -= this.fadeRate;
            }
            draw() {
                if (this.opacity <= 0) return;
                const tailX = this.x - Math.cos(this.angle) * this.length;
                const tailY = this.y - Math.sin(this.angle) * this.length;
                
                const gradient = ctx.createLinearGradient(this.x, this.y, tailX, tailY);
                gradient.addColorStop(0, `rgba(255, 255, 255, ${this.opacity})`);
                gradient.addColorStop(1, `rgba(255, 255, 255, 0)`);
                
                ctx.beginPath();
                ctx.strokeStyle = gradient;
                ctx.lineWidth = this.thickness;
                ctx.moveTo(this.x, this.y);
                ctx.lineTo(tailX, tailY);
                ctx.stroke();
                
                ctx.fillStyle = `rgba(255, 255, 255, ${this.opacity})`;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.thickness, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        let shockwaves = [];
        let shootingStars = [];
        let frameCount = 0;

        function animateBg() {
            requestAnimationFrame(animateBg);
            frameCount++;

            const bgGradient = ctx.createRadialGradient(width/2, height, 0, width/2, height, height * 1.5);
            bgGradient.addColorStop(0, '#0d1d31');
            bgGradient.addColorStop(1, '#020204');
            ctx.fillStyle = bgGradient;
            ctx.fillRect(0, 0, width, height); 

            stars.forEach(star => {
                star.x += star.speedX;
                star.y += star.speedY;

                if (star.x < 0) star.x = width;
                if (star.x > width) star.x = 0;
                if (star.y < 0) star.y = height;
                if (star.y > height) star.y = 0;

                ctx.fillStyle = `rgba(220, 235, 255, ${star.opacity})`;
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
                ctx.fill();
                
                star.opacity += (Math.random() - 0.5) * 0.1;
                if (star.opacity < 0.2) star.opacity = 0.2;
                if (star.opacity > 1) star.opacity = 1;
            });

            const centerX = width / 2;
            const centerY = height / 2;
            
            const coreGradient = ctx.createRadialGradient(centerX, centerY, 2, centerX, centerY, 80);
            coreGradient.addColorStop(0, 'rgba(255, 255, 255, 0.9)');
            coreGradient.addColorStop(0.3, 'rgba(150, 200, 255, 0.2)');
            coreGradient.addColorStop(1, 'rgba(0, 0, 0, 0)');
            
            ctx.fillStyle = coreGradient;
            ctx.beginPath();
            ctx.arc(centerX, centerY, 80, 0, Math.PI * 2);
            ctx.fill();

            ctx.fillStyle = "#fff";
            ctx.beginPath();
            ctx.arc(centerX, centerY, 4, 0, Math.PI * 2);
            ctx.fill();

            if (frameCount % 100 === 0) { shockwaves.push(new Shockwave()); }
            for (let i = shockwaves.length - 1; i >= 0; i--) {
                shockwaves[i].update();
                shockwaves[i].draw();
                if (shockwaves[i].opacity <= 0) { shockwaves.splice(i, 1); }
            }

            if (Math.random() < 0.02) { shootingStars.push(new ShootingStar()); }
            for (let i = shootingStars.length - 1; i >= 0; i--) {
                shootingStars[i].update();
                shootingStars[i].draw();
                if (shootingStars[i].opacity <= 0 || shootingStars[i].x > width || shootingStars[i].y > height) {
                    shootingStars.splice(i, 1);
                }
            }
        }
        
        animateBg();
    </script>
</body>
</html>
